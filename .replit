modules = ["nodejs-20", "python-base-3.13"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]

name = "🚀 Bootstrap"
author = "TK"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node bootstrap.js"

[[workflows.workflow]]

name = "⬆️ Clasp Push"
author = "TK"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && clasp push"

[[workflows.workflow]]

name = "⬇️ Clasp Pull"
author = "TK"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && clasp pull"

[[workflows.workflow]]

name = "☁️ Deploy Worker"
author = "TK"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd worker && npx wrangler deploy"

[[workflows.workflow]]

name = "📤 Git Push"
author = "TK"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git add . && git commit -m 'Update' && git push"

[[workflows.workflow]]

name = "📥 Git Pull"
author = "TK"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git pull"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m http.server 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8787
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 8976
externalPort = 6000
exposeLocalhost = true

[[ports]]
localPort = 9229
externalPort = 3001
exposeLocalhost = true
